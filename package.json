{
  "name": "llm-benchmark-atlas",
  "version": "0.6.0",
  "private": true,
  "description": "A source-grounded, duplication-checked component atlas for LLM benchmark charts.",
  "license": "MIT",
  "types": "types/index.d.ts",
  "scripts": {
    "catalog": "node scripts/export-catalog.mjs",
    "build:site": "node scripts/build-site.mjs",
    "deploy:pages": "bash scripts/deploy-pages.sh",
    "validate": "node scripts/validate-library.mjs",
    "serve": "python3 -m http.server 4173 --bind 127.0.0.1",
    "qa": "python3 scripts/qa_library.py",
    "qa:about": "python3 scripts/qa_about.py"
  },
  "engines": {
    "node": ">=20"
  }
}
