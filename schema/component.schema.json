{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aidennovak.github.io/llm-benchmark-atlas/schema/component.schema.json",
  "title": "Benchmark Atlas component",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "name",
    "chartLabel",
    "family",
    "sourceKey",
    "source",
    "sourceType",
    "sourceUrl",
    "visualSystem",
    "grammar",
    "renderer",
    "description",
    "useWhen",
    "tags",
    "palette",
    "dataNote",
    "data"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "name": { "type": "string", "minLength": 3 },
    "chartLabel": { "type": "string", "minLength": 3 },
    "family": { "type": "string", "minLength": 2 },
    "sourceKey": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9]*$" },
    "source": { "type": "string", "minLength": 2 },
    "sourceType": { "type": "string", "minLength": 2 },
    "sourceUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
    "visualSystem": { "type": "string", "pattern": "^VS-[0-9A-Z]+ " },
    "grammar": { "type": "string", "minLength": 8 },
    "renderer": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9]*$" },
    "description": { "type": "string", "minLength": 12 },
    "useWhen": { "type": "string", "minLength": 12 },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 2 }
    },
    "palette": {
      "type": "object",
      "required": ["bg", "ink", "muted", "grid", "c1", "c2", "c3", "c4", "c5", "c6"],
      "additionalProperties": false,
      "properties": {
        "bg": { "$ref": "#/$defs/color" },
        "ink": { "$ref": "#/$defs/color" },
        "muted": { "$ref": "#/$defs/color" },
        "grid": { "$ref": "#/$defs/color" },
        "c1": { "$ref": "#/$defs/color" },
        "c2": { "$ref": "#/$defs/color" },
        "c3": { "$ref": "#/$defs/color" },
        "c4": { "$ref": "#/$defs/color" },
        "c5": { "$ref": "#/$defs/color" },
        "c6": { "$ref": "#/$defs/color" }
      }
    },
    "dataNote": { "type": "string", "minLength": 8 },
    "evidence": {
      "description": "Figure-level PDF evidence. Required by project validation for figure-verified paper families.",
      "type": "object",
      "additionalProperties": false,
      "required": ["locator", "page", "verifiedAt", "summary"],
      "properties": {
        "locator": { "type": "string", "minLength": 3 },
        "page": { "type": "integer", "minimum": 1 },
        "verifiedAt": { "type": "string", "format": "date" },
        "summary": { "type": "string", "minLength": 12 }
      }
    },
    "data": { "type": "object" }
  },
  "$defs": {
    "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
  }
}
